[Unit]
Description=LockLauncher lock server
After=network.target

[Service]
User=locklauncher
WorkingDirectory=/opt/locklauncher
EnvironmentFile=/opt/locklauncher/.env
ExecStart=/opt/locklauncher/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
