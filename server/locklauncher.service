[Unit]
Description=LockLauncher lock server
After=network.target

[Service]
WorkingDirectory=/root/locklauncher/server
EnvironmentFile=/root/locklauncher/.env
ExecStart=/root/locklauncher/venv/bin/uvicorn main:app --host 0.0.0.0 --port 47291
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
